# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# DATABASE_URL: transaction pooler (pgbouncer, port 6543) — used by the app at runtime.
# DIRECT_URL:   session pooler (port 5432) — used by `prisma migrate` / `db pull`.
# Both come from Supabase Dashboard → Project Settings → Database → Connection string.
# NOTE: the direct host db.<ref>.supabase.co is IPv6-only — from IPv4-only networks use the
# pooler hosts (aws-<n>-<region>.pooler.supabase.com). Percent-encode the password (/ -> %2F).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# Local development without Supabase (docker: postgres on :5433):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/core_tasks?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5433/core_tasks?schema=public"

# ── Auth JWT (HS256, signed with jose) ───────────────────────────────────────
JWT_SECRET="<openssl rand -hex 32>"
JWT_ALGO="HS256"
JWT_TTL="60"            # access-token lifetime in minutes -> expires_in = JWT_TTL * 60 (seconds)
JWT_REFRESH_TTL="20160" # refresh window in minutes (14 days)

# ── CORS (core-tasks-ui origins, comma-separated). localhost:<port> always allowed. ──
CORS_ALLOWED_ORIGINS="http://localhost:4200"

# ── App base URL (used as the JWT `iss` claim). ──────────────────────────────
APP_URL="http://localhost:3002"

# ── Email notifications (AWS SES) ────────────────────────────────────────────
# Opt-in flag: the in-app feed always works; emails only go out when this is "true".
NOTIFICATIONS_EMAIL_ENABLED="true"
AWS_REGION="us-east-1"
# Credentials are resolved by the AWS SDK default chain: shared ~/.aws/credentials locally, or
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY in production. Do NOT commit real keys.
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# Verified SES sender (the micelium.dev domain identity).
SES_FROM="Core Tasks <noreply@micelium.dev>"
# Sandbox guard: only email these recipient domains (comma-separated). Empty = no restriction
# (set once the SES account has production access). Recipients outside the list get in-app only.
SES_ALLOWED_RECIPIENT_DOMAINS="micelium.dev"
# Public UI base, used to build absolute deep links inside emails.
APP_WEB_URL="http://localhost:4200"

# ── Password reset / invite links ────────────────────────────────────────────
# Lifetimes (minutes) of the single-use tokens emailed by forgot-password and new-user invites.
# Emails share the SES config above (NOTIFICATIONS_EMAIL_ENABLED + SES_ALLOWED_RECIPIENT_DOMAINS);
# when delivery is skipped, the link is logged to the server console instead.
# PASSWORD_RESET_TTL="60"
# PASSWORD_INVITE_TTL="10080"
