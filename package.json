{
  "name": "core-tasks-api",
  "version": "1.0.0",
  "private": true,
  "description": "Core Tasks API — Next.js (App Router) API-only backend with Prisma on Supabase Postgres.",
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "prisma generate && next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.mjs",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1085.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@prisma/client": "^6.2.1",
    "@supabase/supabase-js": "^2.110.8",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "mcp-handler": "^1.1.0",
    "next": "^15.1.4",
    "openai": "^6.48.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.12",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3"
  }
}
