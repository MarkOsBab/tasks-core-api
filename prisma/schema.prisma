// Core Tasks — Prisma schema.
//
// Postgres on Supabase. DATABASE_URL points at the pooled (pgbouncer) endpoint for the
// serverless runtime; DIRECT_URL points at the direct 5432 endpoint and is used by
// `prisma migrate` / `prisma db pull`. Locally both can point at the same dev database.
//
// Convention (same as the admin-ui contract): camelCase fields in TS mapped with @map to
// snake_case columns; enums are lowercase strings that must match the UI enums exactly;
// domain entities use soft deletes (deleted_at).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClientStatus {
  active
  inactive
}

enum ProjectStatus {
  draft
  active
  paused
  completed
  archived
}

enum ProposalStatus {
  draft
  sent
  accepted
  rejected
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

model User {
  id        BigInt    @id @default(autoincrement())
  name      String
  lastName  String?   @map("last_name")
  email     String    @unique
  password  String
  image     String?
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  assignedTasks Task[] @relation("TaskAssignee")

  @@map("users")
}

model Client {
  id        BigInt       @id @default(autoincrement())
  name      String
  company   String?
  email     String?
  phone     String?
  notes     String?      @db.Text
  status    ClientStatus @default(active)
  createdAt DateTime?    @default(now()) @map("created_at")
  updatedAt DateTime?    @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  projects Project[]

  @@map("clients")
}

model Project {
  id          BigInt        @id @default(autoincrement())
  clientId    BigInt        @map("client_id")
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(active)
  startDate   DateTime?     @map("start_date") @db.Date
  endDate     DateTime?     @map("end_date") @db.Date
  createdAt   DateTime?     @default(now()) @map("created_at")
  updatedAt   DateTime?     @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  client    Client     @relation(fields: [clientId], references: [id])
  proposals Proposal[]
  tasks     Task[]
  board     Board?

  @@map("projects")
}

model Proposal {
  id          BigInt         @id @default(autoincrement())
  projectId   BigInt         @map("project_id")
  title       String
  description String?        @db.Text
  link        String?        @db.Text // optional external URL (proposal doc, deck, etc.)
  amount      Decimal?       @db.Decimal(12, 2)
  currency    String         @default("USD") @db.VarChar(3)
  status      ProposalStatus @default(draft)
  sentAt      DateTime?      @map("sent_at")
  validUntil  DateTime?      @map("valid_until") @db.Date
  createdAt   DateTime?      @default(now()) @map("created_at")
  updatedAt   DateTime?      @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("proposals")
}

model Task {
  id          BigInt       @id @default(autoincrement())
  columnId    BigInt       @map("column_id") // replaces status: the kanban column the card lives in
  projectId   BigInt?      @map("project_id") // optional now; denormalized = column.board.projectId (null for global tasks)
  title       String
  description String?      @db.Text
  priority    TaskPriority @default(medium)
  position    Int          @default(0)
  dueDate     DateTime?    @map("due_date") @db.Date
  assigneeId  BigInt?      @map("assignee_id")

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  column   BoardColumn @relation(fields: [columnId], references: [id]) // onDelete RESTRICT (default): a column with live tasks cannot be dropped
  project  Project?    @relation(fields: [projectId], references: [id])
  assignee User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([columnId, position])
  @@index([projectId])
  @@map("tasks")
}

model Board {
  id        BigInt    @id @default(autoincrement())
  projectId BigInt?   @unique @map("project_id") // null = the global board (singleton, enforced by a partial index + schema)
  name      String
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  project Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns BoardColumn[]

  @@map("boards")
}

model BoardColumn {
  id         BigInt    @id @default(autoincrement())
  boardId    BigInt    @map("board_id")
  name       String
  color      String?
  position   Int       @default(0)
  wipLimit   Int?      @map("wip_limit")
  isTerminal Boolean   @default(false) @map("is_terminal") // "done" semantics for dashboard open/closed counts
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId, position])
  @@map("board_columns")
}
