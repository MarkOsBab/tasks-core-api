// Core Tasks — Prisma schema.
//
// Postgres on Supabase. DATABASE_URL points at the pooled (pgbouncer) endpoint for the
// serverless runtime; DIRECT_URL points at the direct 5432 endpoint and is used by
// `prisma migrate` / `prisma db pull`. Locally both can point at the same dev database.
//
// Convention (same as the admin-ui contract): camelCase fields in TS mapped with @map to
// snake_case columns; enums are lowercase strings that must match the UI enums exactly;
// domain entities use soft deletes (deleted_at).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClientStatus {
  active
  inactive
}

enum ProjectStatus {
  draft
  active
  paused
  completed
  archived
}

enum ProposalStatus {
  draft
  sent
  accepted
  rejected
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

model User {
  id        BigInt    @id @default(autoincrement())
  name      String
  lastName  String?   @map("last_name")
  email     String    @unique
  password  String
  image     String?
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  assignedTasks Task[]      @relation("TaskAssignee")
  createdTasks  Task[]      @relation("TaskCreator")
  timeEntries   TimeEntry[] @relation("TimeEntryUser")
  comments      Comment[]   @relation("CommentAuthor")

  @@map("users")
}

model Client {
  id        BigInt       @id @default(autoincrement())
  name      String
  company   String?
  email     String?
  phone     String?
  notes     String?      @db.Text
  color     String?      @db.VarChar(7) // hex tag color; auto-assigned on create, user-customizable
  status    ClientStatus @default(active)
  createdAt DateTime?    @default(now()) @map("created_at")
  updatedAt DateTime?    @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  projects Project[]

  @@map("clients")
}

model Project {
  id             BigInt        @id @default(autoincrement())
  clientId       BigInt        @map("client_id")
  name           String
  description    String?       @db.Text
  color          String?       @db.VarChar(7) // hex, unique-per-project visual identity (auto-assigned)
  estimatedHours Decimal?      @map("estimated_hours") @db.Decimal(6, 2)
  status         ProjectStatus @default(active)
  startDate      DateTime?     @map("start_date") @db.Date
  endDate        DateTime?     @map("end_date") @db.Date
  createdAt      DateTime?     @default(now()) @map("created_at")
  updatedAt      DateTime?     @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  client    Client     @relation(fields: [clientId], references: [id])
  proposals Proposal[]
  tasks     Task[]
  board     Board?

  @@map("projects")
}

model Proposal {
  id          BigInt         @id @default(autoincrement())
  projectId   BigInt         @map("project_id")
  title       String
  description String?        @db.Text
  link        String?        @db.Text // optional external URL (proposal doc, deck, etc.)
  amount      Decimal?       @db.Decimal(12, 2)
  currency    String         @default("USD") @db.VarChar(3)
  status      ProposalStatus @default(draft)
  sentAt      DateTime?      @map("sent_at")
  validUntil  DateTime?      @map("valid_until") @db.Date
  createdAt   DateTime?      @default(now()) @map("created_at")
  updatedAt   DateTime?      @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("proposals")
}

model Task {
  id          BigInt       @id @default(autoincrement())
  columnId    BigInt       @map("column_id") // replaces status: the kanban column the card lives in
  projectId   BigInt?      @map("project_id") // optional now; denormalized = column.board.projectId (null for global tasks)
  title       String
  description String?      @db.Text
  priority    TaskPriority @default(medium)
  position    Int          @default(0)
  dueDate     DateTime?    @map("due_date") @db.Date
  assigneeId  BigInt?      @map("assignee_id")
  createdById BigInt?      @map("created_by_id") // auth user that created the card

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  column      BoardColumn @relation(fields: [columnId], references: [id]) // onDelete RESTRICT (default): a column with live tasks cannot be dropped
  project     Project?    @relation(fields: [projectId], references: [id])
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy   User?       @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  timeEntries    TimeEntry[]
  comments       Comment[]
  labels         Label[]
  checklistItems ChecklistItem[]

  @@index([columnId, position])
  @@index([projectId])
  @@map("tasks")
}

model TimeEntry {
  id              BigInt    @id @default(autoincrement())
  taskId          BigInt    @map("task_id")
  userId          BigInt    @map("user_id")
  description     String?   @db.Text
  startedAt       DateTime  @map("started_at")
  endedAt         DateTime? @map("ended_at") // null = timer still running
  durationSeconds Int?      @map("duration_seconds") // closed-entry length, kept in sync by the service (Prisma can't filter on ended_at - started_at)
  createdAt       DateTime? @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id])
  user User @relation("TimeEntryUser", fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId, endedAt]) // fast lookup of a user's running timer
  @@index([startedAt]) // tracking-date filters + default timesheet order
  @@map("time_entries")
}

model Comment {
  id        BigInt    @id @default(autoincrement())
  taskId    BigInt    @map("task_id")
  userId    BigInt    @map("user_id") // author, stamped from the auth user on create
  body      String    @db.Text
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id])
  user User @relation("CommentAuthor", fields: [userId], references: [id])

  @@index([taskId])
  @@map("comments")
}

model Label {
  id        BigInt    @id @default(autoincrement())
  name      String
  color     String?   @db.VarChar(7) // hex tag color; auto-assigned on create, user-customizable
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tasks Task[] // implicit m2m; Prisma manages the _LabelToTask pivot

  @@map("labels")
}

model ChecklistItem {
  id        BigInt    @id @default(autoincrement())
  taskId    BigInt    @map("task_id")
  title     String
  done      Boolean   @default(false)
  position  Int       @default(0)
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id])

  @@index([taskId, position])
  @@map("checklist_items")
}

model Board {
  id        BigInt    @id @default(autoincrement())
  projectId BigInt?   @unique @map("project_id") // null = the global board (singleton, enforced by a partial index + schema)
  name      String
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  project Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns BoardColumn[]

  @@map("boards")
}

model BoardColumn {
  id         BigInt    @id @default(autoincrement())
  boardId    BigInt    @map("board_id")
  name       String
  color      String?
  position   Int       @default(0)
  wipLimit   Int?      @map("wip_limit")
  isTerminal Boolean   @default(false) @map("is_terminal") // "done" semantics for dashboard open/closed counts
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId, position])
  @@map("board_columns")
}
